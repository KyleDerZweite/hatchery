# Local development. Copy to .env (./dev.sh does this for you) and run ./dev.sh.
#
# AUTH_MODE=dev signs you in as a fixed local user and requires no identity
# provider. It is refused unless DATABASE_URL is the local SQLite file.
AUTH_MODE=dev

# Optional: required only to import CurseForge modpacks. Modrinth needs no key.
CURSEFORGE_API_KEY=

# --- Production (see OPERATIONS.md) ---------------------------------------
# Leave AUTH_MODE unset or set it to zitadel. The API refuses to start unless
# every value below is present.
#
# AUTH_MODE=zitadel
# DATABASE_URL=postgresql://hatchery:CHANGE_ME@postgres:5432/hatchery
# POSTGRES_PASSWORD=CHANGE_ME
# PANEL_API_KEY_ENCRYPTION_SECRET=   # openssl rand -hex 32; rotating it invalidates stored panel keys
# ZITADEL_DOMAIN=auth.example.com    # no scheme
# ZITADEL_PROJECT_ID=                # JWT audience
# ZITADEL_CLIENT_ID=                 # OIDC client for the browser app
#
# Only when the browser app is served from a different origin than the API:
# CORS_ORIGINS=["https://hatchery.example.com"]
