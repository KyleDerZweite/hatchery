DATABASE_URL=postgresql://hatchery:hatchery@postgres:5432/hatchery
# Generate real values for production, e.g. `openssl rand -hex 32`
SECRET_KEY=change-me
PANEL_API_KEY_ENCRYPTION_SECRET=change-me
CURSEFORGE_API_KEY=

# ZITADEL_DOMAIN (backend, no scheme) and VITE_ZITADEL_AUTHORITY (frontend,
# with scheme) must point at the same Zitadel instance.
ZITADEL_DOMAIN=auth.example.com
# Required: API auth rejects every token until this is set.
ZITADEL_PROJECT_ID=

# JSON list of allowed browser origins for the API. Only needed when the
# frontend is served from an origin other than the compose defaults.
#CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Leave empty to use relative /api (proxied to the backend by nginx).
VITE_API_URL=
VITE_ZITADEL_AUTHORITY=https://auth.example.com
VITE_ZITADEL_CLIENT_ID=
VITE_ZITADEL_REDIRECT_URI=http://localhost:3000/callback
VITE_ZITADEL_POST_LOGOUT_URI=http://localhost:3000/login

POSTGRES_USER=hatchery
POSTGRES_PASSWORD=hatchery
POSTGRES_DB=hatchery

PANGOLIN_ENDPOINT=
NEWT_ID=
NEWT_SECRET=
